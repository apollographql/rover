    "@apollo/rover-darwin-x64": "0.40.0",
    "@apollo/rover-linux-arm64": "0.40.0",
    "@apollo/rover-linux-x64": "0.40.0",
    "@apollo/rover-linux-x64-musl": "0.40.0",
